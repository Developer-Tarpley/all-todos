gitignore file# Ignore all files in the logs directory, but not the .gitkeep file
logs/*
!logs/.gitkeep

# Ignore the entire tmp directory
tmp/

# Ignore all files with .swp extension
*.swp

# Dependencies
node_modules/

# Build output
dist/
build/
out/
coverage/

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Cache
.cache/
.parcel-cache/
.next/
.nuxt/
.svelte-kit/
vite.config.ts.timestamp*

# System files
.DS_Store
Thumbs.db

# Editor settings
.vscode/
.idea/

# Misc
*.swp
*.tmp
*.temp
*.pid
*.seed
*.tgz